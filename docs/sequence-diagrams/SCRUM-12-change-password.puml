@startuml SCRUM-12 Change Password

title Change password while signed in (SCRUM-12)

actor User as U
participant "Browser\n(Bootstrap form)" as B
participant "AuthFilter" as AF
participant "ChangePasswordServlet\nPOST /protected/account/password" as CP
participant "UserDAO" as DAO
participant "SecurityUtil\nverifyPassword / hashPassword" as SU
database "PostgreSQL\n(users.password)" as DB
participant "HttpSession" as S

U -> B : Submit current + new + confirm
B -> AF : POST
AF -> CP : chain

activate CP
CP -> S : session userId, sessionEmail
activate S
S --> CP
deactivate S

CP -> CP : InputValidator password policy;\nnew == confirm;\nnew != current (policy)

CP -> DAO : getUserByEmail(sessionEmail)\n(load hash)
activate DAO
DAO -> DB : SELECT … password …
DB --> DAO : User + stored hash
DAO --> CP
deactivate DAO

CP -> SU : verifyPassword(current, storedHash)
activate SU
SU --> CP : false / true
deactivate SU

alt wrong current password (SCRUM-196)
    CP -> B : forward form + error
else valid
    CP -> SU : hashPassword(newPassword)\n(Salted SHA-256, format 1\$…)
    activate SU
    SU --> CP : new stored hash
    deactivate SU
    CP -> DAO : updatePassword(email, newHash)
    activate DAO
    DAO -> DB : UPDATE users SET password = ?
    DB --> DAO : ok
    deactivate DAO
    CP -> S : invalidate()
    note right of S : **SCRUM-197:** force re-login\nwith new credentials
    CP -> B : redirect /login?passwordChanged=1
end
deactivate CP

@enduml
